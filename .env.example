# ═══ Supabase credentials ═══
# Appka funguje i bez nich (data se ukládají do localStorage).
# Pro cloud sync + přihlášení:
#   1. Vytvoř projekt na https://supabase.com (free tier stačí)
#   2. Settings → API → zkopíruj URL a anon key
#   3. Authentication → Providers → zapni Google OAuth
#      (potřebuješ Google Cloud Console OAuth 2.0 Client ID)
#   4. SQL Editor → spusť CREATE TABLE (viz README.md)

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
